    "@chimera/core": "workspace:*",
    "@chimera/permissions": "workspace:*",
    "@chimera/providers": "workspace:*",
    "@chimera/sandbox": "workspace:*",
    "@chimera/server": "workspace:*",
    "@chimera/skills": "workspace:*",
    "@chimera/subagents": "workspace:*",
    "@chimera/tools": "workspace:*",
    "@chimera/tui": "workspace:*",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "ai": "^6.0.168",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
