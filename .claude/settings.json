{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cerberus session-start"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cerberus track-file"
          },
          {
            "type": "command",
            "command": "cerberus run quick --agent claude-code",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cerberus run standard --agent claude-code",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
